proc print():
    loop:
        reg al = *u8:reg esi

        when reg al == 0:
            break
        end

        reg ah = 0x0f
        *u16:reg edi = reg ax

        reg esi++
        reg edi = reg edi + 2
    end

    ret

proc move_cursor():
    reg edi = vga + cast(u32, curr_row * cast(u8, cols * 2) + curr_col * 2)

    ret