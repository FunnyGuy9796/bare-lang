proc vga_print():
    loop:
        reg al = *u8:reg esi

        when reg al == 0:
            break
        end

        reg bl = fg_color
        reg bh = bg_color
        reg bh = reg bh << 4
        reg ah = reg bl | reg bh
        *u16:reg edi = reg ax

        reg esi++
        reg edi = reg edi + 2
    end

    ret

proc vga_move_cursor():
    reg edi = vga + cast(u32, curr_row * cast(u8, vga_cols * 2) + curr_col * 2)

    ret