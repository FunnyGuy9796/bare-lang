section .multiboot:
dd 0x1badb002
dd 0x00
dd 0xe4524ffe

section .rodata:
const msg: u8 = "Hello from bare lang"
const msg2: u8 = "This is a basic program running on i686 bare metal"
const rows: u8 = 25
const cols: u8 = 80

section .text:
bits 32

proc _start():
    cli

    reg esp = 0x9000
    reg esi = &msg
    reg edi = 0xb8000

    print()

    reg esi = &msg2
    reg edi = cast(u32, cols * 2)

    loop:
        hlt
    end

#include "vga.bare"