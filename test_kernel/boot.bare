section .rodata:
    const msg: u8 = "Hello from bare lang"
    const msg2: u8 = "This is a basic program running on i686 bare metal"

section .text:
bits 16

proc _start():
    cli

    reg ax = 0
    seg ds = reg ax
    seg es = reg ax
    seg ss = reg ax
    reg sp = 0x7C00

    sti

    reg ax = 0xb800
    seg es = reg ax

    reg si = addr msg
    reg di = 0

    loop:
        reg al = &u8:reg si

        when reg al == 0:
            break
        end

        reg ah = 0x0f
        &u16:es:reg di = reg ax

        reg si = reg si + 1
        reg di = reg di + 2
    end

    reg si = addr msg2
    reg di = 160

    loop:
        reg al = &u8:reg si

        when reg al == 0:
            break
        end

        reg ah = 0x0f
        &u16:es:reg di = reg ax

        reg si = reg si + 1
        reg di = reg di + 2
    end

    loop:
        hlt
    end

section .bootsig:
dw 0xaa55